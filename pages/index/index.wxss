.container {
  padding-bottom: 20rpx;
}

.search-bar {
  padding: 20rpx 30rpx;
  background: #fff;
}

.search-input {
  display: flex;
  align-items: center;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-placeholder {
  font-size: 28rpx;
  color: #999;
}

.banner-swiper {
  width: 100%;
  height: 320rpx;
  margin: 20rpx 0;
}

.banner-image {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
  margin: 0 20rpx;
}

swiper {
  padding: 0 20rpx;
  box-sizing: border-box;
}

swiper-item {
  border-radius: 16rpx;
  overflow: hidden;
}

.category-section {
  background: #fff;
  margin: 20rpx 20rpx;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
}

.category-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 28rpx;
}

.category-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 12rpx;
}

.category-name {
  font-size: 24rpx;
  color: #666;
}

.hot-section {
  background: #fff;
  margin: 0 20rpx;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-header .section-title {
  margin-bottom: 0;
}

.section-more {
  font-size: 26rpx;
  color: #999;
}

.hot-scroll {
  width: 100%;
  white-space: nowrap;
}

.hot-item {
  display: inline-block;
  width: 240rpx;
  margin-right: 20rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #fafafa;
}

.hot-item:last-child {
  margin-right: 0;
}

.hot-image-wrap {
  position: relative;
  width: 100%;
  height: 240rpx;
}

.hot-image {
  width: 100%;
  height: 100%;
}

.hot-tag {
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  background: linear-gradient(135deg, #ff6b35, #ff8c42);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.hot-info {
  padding: 16rpx;
}

.hot-name {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.hot-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hot-sales {
  font-size: 22rpx;
  color: #bbb;
}

.cart-entry {
  position: fixed;
  bottom: 120rpx;
  right: 30rpx;
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #ff6b35, #ff8c42);
  color: #fff;
  padding: 16rpx 24rpx;
  border-radius: 44rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.4);
  z-index: 100;
}

.cart-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 40rpx;
  height: 40rpx;
  background: #fff;
  color: #ff6b35;
  font-size: 22rpx;
  font-weight: bold;
  border-radius: 20rpx;
  margin-right: 12rpx;
  padding: 0 10rpx;
}

.cart-text {
  font-size: 28rpx;
}

.cart-arrow {
  font-size: 24rpx;
  margin-left: 8rpx;
}