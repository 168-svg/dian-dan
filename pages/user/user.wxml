<view class="container">
  <view class="user-header">
    <view class="user-info" wx:if="{{hasLogin}}">
      <image class="avatar" src="{{userInfo.avatar}}" mode="aspectFill" />
      <view class="user-info-detail">
        <view class="nickname-row">
          <text class="nickname">{{userInfo.nickname}}</text>
          <view class="guest-tag" wx:if="{{isGuest}}">游客</view>
        </view>
        <text class="user-tip" wx:if="{{isGuest}}">点击下方按钮可以切换为正式账号登录</text>
      </view>
    </view>
    <view class="login-area" wx:else>
      <image class="avatar-placeholder" src="/images/user/default-avatar.png" mode="aspectFill" />
      <view class="login-buttons">
        <view class="login-btn wechat-btn" bindtap="onLoginTap">
          <text class="btn-icon">👤</text>
          <text class="btn-text">账号登录</text>
        </view>
        <view class="login-btn wechat-btn register-btn" bindtap="onRegisterTap">
          <text class="btn-icon">📝</text>
          <text class="btn-text">注册新账号</text>
        </view>
        <view class="login-btn guest-btn" bindtap="onGuestLoginTap">
          <text class="btn-icon">👥</text>
          <text class="btn-text">游客登录</text>
        </view>
      </view>
    </view>
  </view>

  <view class="switch-login-btn" wx:if="{{hasLogin && isGuest}}" bindtap="onLoginTap">
    <text class="switch-icon">👤</text>
    <text class="switch-text">切换为正式账号登录</text>
  </view>

  <view class="order-section">
    <view class="section-header" bindtap="onAllOrders">
      <text class="section-title">我的订单</text>
      <text class="section-more">全部订单 ></text>
    </view>
    <view class="order-grid">
      <view class="order-grid-item" bindtap="onOrderTap" data-status="pending">
        <text class="grid-icon">📝</text>
        <text class="grid-label">待处理</text>
      </view>
      <view class="order-grid-item" bindtap="onOrderTap" data-status="cooking">
        <text class="grid-icon">👨‍🍳</text>
        <text class="grid-label">制作中</text>
      </view>
      <view class="order-grid-item" bindtap="onOrderTap" data-status="done">
        <text class="grid-icon">✅</text>
        <text class="grid-label">已完成</text>
      </view>
      <view class="order-grid-item" bindtap="onAllOrders">
        <text class="grid-icon">📋</text>
        <text class="grid-label">全部</text>
      </view>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="onAddress">
      <text class="menu-icon">📍</text>
      <text class="menu-label">地址管理</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="onCoupon">
      <text class="menu-icon">🎫</text>
      <text class="menu-label">优惠券</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="onService">
      <text class="menu-icon">📞</text>
      <text class="menu-label">联系客服</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="onAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-label">关于我们</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="onClearCache">
      <text class="menu-icon">🗑️</text>
      <text class="menu-label">清除缓存</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <view class="logout-section" wx:if="{{hasLogin}}">
    <view class="logout-btn" bindtap="onLogout">
      <text>退出登录</text>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{showLoginModal}}" bindtap="closeLoginModal">
    <view class="modal-content" catchtap="">
      <view class="modal-title">
        <text wx:if="{{loginType === 'login'}}">登录账号</text>
        <text wx:elif="{{loginType === 'register'}}">注册账号</text>
        <text wx:else>游客登录</text>
      </view>

      <view wx:if="{{loginType === 'login' || loginType === 'register'}}">
        <view class="form-row">
          <input class="form-input" placeholder="用户名" value="{{loginForm.username}}" data-field="username" bindinput="onInput" />
        </view>
        <view class="form-row">
          <input class="form-input" placeholder="密码" password value="{{loginForm.password}}" data-field="password" bindinput="onInput" />
        </view>
        <view class="form-row" wx:if="{{loginType === 'register'}}">
          <input class="form-input" placeholder="昵称（可选）" value="{{loginForm.nickname}}" data-field="nickname" bindinput="onInput" />
        </view>
        <view class="form-row" wx:if="{{loginType === 'register'}}">
          <input class="form-input" placeholder="手机号（可选）" value="{{loginForm.phone}}" data-field="phone" bindinput="onInput" type="number" />
        </view>
      </view>

      <view wx:if="{{loginType === 'guest'}}" class="guest-tip-box">
        <text class="guest-tip">游客登录后将使用系统自动分配的账号，下单和订单信息将与该账号关联。</text>
      </view>

      <view class="modal-switch">
        <view class="switch-link" wx:if="{{loginType === 'login'}}" data-type="register" bindtap="switchLoginType">还没有账号？去注册</view>
        <view class="switch-link" wx:if="{{loginType === 'register'}}" data-type="login" bindtap="switchLoginType">已有账号？去登录</view>
        <view class="switch-link" data-type="guest" bindtap="switchLoginType">也可以用游客登录</view>
      </view>

      <view class="modal-footer">
        <view class="modal-btn cancel" bindtap="closeLoginModal">取消</view>
        <view class="modal-btn confirm" bindtap="confirmLogin">
          <text wx:if="{{loginType === 'login'}}">登录</text>
          <text wx:elif="{{loginType === 'register'}}">注册</text>
          <text wx:else>游客登录</text>
        </view>
      </view>
    </view>
  </view>
</view>
