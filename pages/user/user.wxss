.container {
  min-height: 100vh;
}

.user-header {
  background: linear-gradient(135deg, #ff6b35, #ff8c42);
  padding: 60rpx 30rpx 40rpx;
  display: flex;
  align-items: center;
}

.user-info {
  display: flex;
  align-items: center;
  width: 100%;
}

.user-info-detail {
  flex: 1;
  margin-left: 24rpx;
}

.nickname-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  flex-shrink: 0;
}

.nickname {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
}

.guest-tag {
  background: rgba(255, 255, 255, 0.3);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-left: 16rpx;
  font-size: 22rpx;
  color: #fff;
}

.user-tip {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.login-area {
  display: flex;
  align-items: center;
  width: 100%;
  flex-direction: column;
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  margin-bottom: 30rpx;
}

.login-buttons {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  width: 100%;
  align-items: center;
}

.login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  width: 400rpx;
}

.wechat-btn {
  background: #fff;
  color: #ff6b35;
}

.guest-btn {
  background: rgba(255, 255, 255, 0.3);
  color: #fff;
  border: 2rpx solid rgba(255, 255, 255, 0.6);
}

.btn-icon {
  margin-right: 12rpx;
  font-size: 32rpx;
}

.btn-text {
  font-size: 28rpx;
  font-weight: bold;
}

.switch-login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  margin: 20rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  margin-top: -20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.switch-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.switch-text {
  font-size: 28rpx;
  color: #ff6b35;
  font-weight: bold;
}

.order-section {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 24rpx;
  color: #999;
}

.order-grid {
  display: flex;
}

.order-grid-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.grid-icon {
  font-size: 44rpx;
  margin-bottom: 10rpx;
}

.grid-label {
  font-size: 24rpx;
  color: #666;
}

.grid-badge {
  position: absolute;
  top: -6rpx;
  right: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: #ff6b35;
  color: #fff;
  font-size: 20rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.menu-section {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-label {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.menu-arrow {
  font-size: 26rpx;
  color: #ccc;
}

.logout-section {
  padding: 40rpx 20rpx;
}

.logout-btn {
  background: #fff;
  padding: 24rpx;
  border-radius: 16rpx;
  text-align: center;
  font-size: 30rpx;
  color: #ff6b35;
  font-weight: bold;
}
