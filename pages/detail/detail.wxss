.container {
    min-height: 100vh;
    background: #f5f5f5;
}

.video-section {
    position: relative;
    width: 100%;
    height: 420rpx;
    background: #000;
}

.detail-video {
    width: 100%;
    height: 100%;
}

.video-mask {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.3);
    pointer-events: none;
}

.play-btn {
    width: 100rpx;
    height: 100rpx;
    background: rgba(255, 255, 255, 0.9);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
}

.play-icon {
    font-size: 40rpx;
    color: #ff6b35;
    margin-left: 6rpx;
}

.info-section {
    background: #fff;
    margin: 20rpx;
    border-radius: 16rpx;
    padding: 30rpx;
}

.info-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16rpx;
}

.food-name {
    font-size: 36rpx;
    font-weight: bold;
    color: #333;
}

.food-sales {
    font-size: 24rpx;
    color: #bbb;
    flex-shrink: 0;
    margin-left: 20rpx;
}

.price-row {
    display: flex;
    align-items: baseline;
    margin-bottom: 24rpx;
    padding-bottom: 24rpx;
    border-bottom: 1rpx solid #f0f0f0;
}

.current-price {
    font-size: 44rpx;
    font-weight: bold;
}

.original-price {
    font-size: 26rpx;
    color: #ccc;
    text-decoration: line-through;
    margin-left: 16rpx;
}

.desc-row {
    display: flex;
    margin-bottom: 20rpx;
}

.desc-label {
    font-size: 28rpx;
    color: #999;
    flex-shrink: 0;
    margin-right: 20rpx;
    width: 80rpx;
}

.desc-text {
    font-size: 28rpx;
    color: #666;
    line-height: 1.6;
}

.detail-row {
    display: flex;
}

.detail-text {
    font-size: 26rpx;
    color: #888;
    line-height: 1.8;
    flex: 1;
}

.related-section {
    background: #fff;
    margin: 0 20rpx;
    border-radius: 16rpx;
    padding: 30rpx 20rpx;
}

.section-title {
    font-size: 30rpx;
    font-weight: bold;
    color: #333;
    margin-bottom: 20rpx;
}

.related-scroll {
    width: 100%;
    white-space: nowrap;
}

.related-item {
    display: inline-block;
    width: 200rpx;
    margin-right: 16rpx;
    border-radius: 12rpx;
    overflow: hidden;
    background: #fafafa;
}

.related-item:last-child {
    margin-right: 0;
}

.related-image {
    width: 100%;
    height: 200rpx;
}

.related-info {
    padding: 12rpx;
}

.related-name {
    display: block;
    font-size: 24rpx;
    color: #333;
    margin-bottom: 8rpx;
}

.cart-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    align-items: center;
    height: 100rpx;
    background: #fff;
    padding: 0 30rpx;
    box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.08);
    z-index: 100;
    padding-bottom: constant(safe-area-inset-bottom);
    padding-bottom: env(safe-area-inset-bottom);
}

.cart-info {
    display: flex;
    align-items: center;
    flex-shrink: 0;
}

.cart-icon-wrap {
    position: relative;
    width: 72rpx;
    height: 72rpx;
    background: #ff6b35;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.4);
}

.cart-icon {
    font-size: 36rpx;
}

.cart-badge {
    position: absolute;
    top: -4rpx;
    right: -4rpx;
    min-width: 36rpx;
    height: 36rpx;
    background: #fff;
    color: #ff6b35;
    font-size: 20rpx;
    font-weight: bold;
    border-radius: 18rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 8rpx;
    box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
}

.cart-controls {
    display: flex;
    align-items: center;
    margin-left: 30rpx;
}

.btn-reduce {
    width: 48rpx;
    height: 48rpx;
    border-radius: 50%;
    border: 2rpx solid #ff6b35;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 30rpx;
    color: #ff6b35;
    font-weight: bold;
}

.count-text {
    width: 60rpx;
    text-align: center;
    font-size: 30rpx;
    color: #333;
    font-weight: bold;
}

.add-btn {
    flex: 1;
    background: linear-gradient(135deg, #ff6b35, #ff8c42);
    color: #fff;
    font-size: 28rpx;
    padding: 20rpx 0;
    border-radius: 40rpx;
    text-align: center;
    font-weight: bold;
    margin-left: 30rpx;
}