.container {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.cart-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 100rpx；
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #bbb;
  margin-bottom: 40rpx;
}

.go-menu-btn {
  background: linear-gradient(135deg, #ff6b35, #ff8c42);
  color: #fff;
  font-size: 28rpx;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
}

.cart-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  background: #fff;
  margin-bottom: 2rpx;
}

.header-title {
  font-size: 28rpx;
  color: #333;
}

.clear-btn {
  font-size: 26rpx;
  color: #999;
  padding: 8rpx 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 20rpx;
}

.cart-list {
  background: #fff;
}

.cart-item {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.cart-item-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.cart-item-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  height: 140rpx;
  justify-content: space-between;
}

.cart-item-name {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.cart-item-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.cart-control {
  display: flex;
  align-items: center;
}

.btn-reduce {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #ff6b35;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #ff6b35;
  font-weight: bold;
}

.btn-add {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #ff6b35;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
}

.count-text {
  width: 50rpx;
  text-align: center;
  font-size: 26rpx;
  color: #333;
  font-weight: bold;
}

.item-total {
  font-size: 30rpx;
}

.remove-btn {
  color: #ccc;
  font-size: 24rpx;
  padding: 12rpx;
  margin-left: 16rpx;
}

.remark-section {
  display: flex;
  align-items: center;
  background: #fff;
  margin-top: 20rpx;
  padding: 24rpx 30rpx;
}

.remark-label {
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.remark-input {
  flex: 1;
  font-size: 26rpx;
  height: 60rpx;
}

.cart-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  background: #fff;
  padding: 0 30rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.footer-total {
  display: flex;
  align-items: baseline;
}

.total-label {
  font-size: 28rpx;
  color: #333;
}

.total-price {
  font-size: 36rpx;
  font-weight: bold;
}

.submit-btn {
  background: linear-gradient(135deg, #ff6b35, #ff8c42);
  color: #fff;
  font-size: 30rpx;
  padding: 20rpx 48rpx;
  border-radius: 40rpx;
  font-weight: bold;
}