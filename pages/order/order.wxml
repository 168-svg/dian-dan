<view class="container">
  <view class="tab-bar">
    <view
      class="tab-item {{currentTab === index ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="index"
      wx:for-item="tab"
      wx:for-index="index"
      bindtap="onTabTap"
      data-index="{{index}}"
    >
      <text>{{tab}}</text>
    </view>
  </view>

  <view class="order-empty" wx:if="{{isEmpty}}">
    <text class="empty-icon">📋</text>
    <text class="empty-text">暂无订单</text>
    <text class="empty-desc">快去下单吧~</text>
    <view class="go-menu-btn" bindtap="onGoMenu">去点餐</view>
  </view>

  <view class="order-list" wx:else>
    <view class="order-item" wx:for="{{orders}}" wx:key="id">
      <view class="order-header">
        <text class="order-id">订单号：{{item.order_no || item.id}}</text>
        <text class="order-status status-{{item.status}}">{{item.statusText}}</text>
      </view>

      <view class="order-foods">
        <view class="order-food" wx:for="{{item.items}}" wx:key="id" wx:for-item="food">
          <image class="order-food-image" src="{{food.image || '/images/user/default-avatar.png'}}" mode="aspectFill" />
          <view class="order-food-info">
            <text class="food-name text-ellipsis">{{food.name}}</text>
            <view class="food-bottom">
              <text class="food-count">x{{food.count}}</text>
              <text class="food-price price">¥{{food.price}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="order-footer">
        <text class="order-time">{{item.createTime}}</text>
        <view class="order-actions">
          <text class="order-total">合计：<text class="price">¥{{item.totalText}}</text></text>
          <view class="action-btn" catchtap="onOrderDetail" data-id="{{item.id}}">详情</view>
          <view class="action-btn" wx:if="{{item.status === 'pending'}}" catchtap="onCancelOrder" data-id="{{item.id}}">取消</view>
          <view class="action-btn action-delete" wx:if="{{item.status === 'completed' || item.status === 'cancelled'}}" catchtap="onDeleteOrder" data-id="{{item.id}}">删除</view>
        </view>
      </view>
    </view>
  </view>
</view>