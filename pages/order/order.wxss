.container {
  min-height: 100vh;
}

.tab-bar {
  display: flex;
  background: #fff;
  padding: 0 20rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #ff6b35;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #ff6b35;
  border-radius: 2rpx;
}

.order-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #bbb;
  margin-bottom: 40rpx;
}

.go-menu-btn {
  background: linear-gradient(135deg, #ff6b35, #ff8c42);
  color: #fff;
  font-size: 28rpx;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
}

.order-list {
  padding: 20rpx;
}

.order-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.order-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-id {
  font-size: 24rpx;
  color: #999;
}

.order-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.status-pending {
  background: #fff3e0;
  color: #ff9800;
}

.status-cooking {
  background: #e3f2fd;
  color: #2196f3;
}

.status-done {
  background: #e8f5e9;
  color: #4caf50;
}

.order-foods {
  padding: 16rpx 0;
}

.order-food {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
}

.order-food-image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.order-food-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.order-food .food-name {
  font-size: 26rpx;
  color: #333;
}

.food-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 4rpx;
}

.order-food .food-count {
  font-size: 24rpx;
  color: #999;
}

.order-food .food-price {
  font-size: 26rpx;
}

.order-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.order-time {
  font-size: 22rpx;
  color: #ccc;
}

.order-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.order-total {
  font-size: 26rpx;
  color: #333;
  margin-right: 12rpx;
}

.action-btn {
  font-size: 24rpx;
  color: #ff6b35;
  padding: 8rpx 24rpx;
  border: 1rpx solid #ff6b35;
  border-radius: 20rpx;
}

.action-delete {
  color: #ccc;
  border-color: #ddd;
}